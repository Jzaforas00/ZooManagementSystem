<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Zoo</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="site-header">
        <div class="header-backdrop"></div>
        <div class="container navwrap">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">Zoo</span>
                <span class="brand-text">
                    <strong>Zoo Management</strong>
                    <small>Control operativo y gestión integral</small>
                </span>
            </a>
            <nav class="main-nav" aria-label="Principal">
                <a asp-controller="Home" asp-action="Index">Inicio</a>
                <a asp-controller="Management" asp-action="Index">Cuadro de mando</a>
                <div class="nav-dropdown">
                    <button type="button" class="nav-dropdown-toggle">Gestión</button>
                    <div class="nav-dropdown-menu">
                        <a asp-controller="Animals" asp-action="Index">Animales</a>
                        <a asp-controller="Alimentos" asp-action="Index">Alimentos</a>
                        <a asp-controller="Dosis" asp-action="Index">Dosis</a>
                        <a asp-controller="Jaulas" asp-action="Index">Jaulas</a>
                        <a asp-controller="Zonas" asp-action="Index">Zonas</a>
                        <a asp-controller="Ecosistemas" asp-action="Index">Ecosistemas</a>
                        <a asp-controller="Empleados" asp-action="Index">Empleados</a>
                        <a asp-controller="CategoriasLaborales" asp-action="Index">Categorías laborales</a>
                        <a asp-controller="Proveedores" asp-action="Index">Proveedores</a>
                    </div>
                </div>
            </nav>
        </div>
    </header>
    <main class="container maincontent">
        @RenderBody()
    </main>
    <footer class="site-footer">
        <div class="container">
            <span>Zoo Management System</span>
            <span>Entorno de administración, catalogación y explotación del zoo.</span>
        </div>
    </footer>
</body>
</html>
