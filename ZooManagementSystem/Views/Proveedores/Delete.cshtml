@model Proveedor
@{
    ViewData["Title"] = "Eliminar proveedor";
}

<h1>Eliminar proveedor</h1>
<p>¿Seguro que quieres eliminar el proveedor <strong>@Model.Nombre</strong>?</p>
<form method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit">Eliminar</button>
    <a asp-action="Index" class="secondary-btn">Cancelar</a>
</form>
