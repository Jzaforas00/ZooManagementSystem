@model Ecosistema
@{
    ViewData["Title"] = "Eliminar ecosistema";
}

<h1>Eliminar ecosistema</h1>
<div class="detail-card">
    <p>¿Seguro que quieres eliminar el ecosistema <strong>@Model.Descripcion</strong>?</p>
    <h3>Imagen</h3>
    @await Html.PartialAsync("_UrlImagePreview", Model.Url ?? string.Empty)
</div>
<form method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit">Eliminar</button>
    <a asp-action="Index" class="secondary-btn">Cancelar</a>
</form>
