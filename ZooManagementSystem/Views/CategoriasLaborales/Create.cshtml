@model CategoriaLaboral
@{
    ViewData["Title"] = "Crear categoría";
}

<h1>Crear categoría laboral</h1>
<form method="post" class="form-grid">
    <label>Descripción</label>
    <input asp-for="Descripcion" />

    <label>Sueldo</label>
    <input asp-for="Sueldo" />

    <div class="form-actions">
        <button type="submit">Guardar</button>
        <a asp-action="Index" class="secondary-btn">Cancelar</a>
    </div>
</form>
